+static size_t ksu_susfs_append_feature(char *buf, size_t buf_size, size_t len, const char *feature)
+{
+    size_t feature_len = strlen(feature);
+
+    if (len >= buf_size)
+        return len;
+
+    if (feature_len > buf_size - len - 1)
+        feature_len = buf_size - len - 1;
+
+    memcpy(buf + len, feature, feature_len);
+    len += feature_len;
+    buf[len] = '\0';
+
+    return len;
+}
+
+static int ksu_susfs_copy_string_to_user(void __user *arg, const char *value)
+{
+    size_t len = strlen(value) + 1;
+
+    if (!arg || IS_ERR(arg))
+        return -EINVAL;
+
+    if (!ksu_access_ok(arg, len))
+        return -EFAULT;
+
+    return copy_to_user(arg, value, len) ? -EFAULT : 0;
+}
+
+static bool ksu_susfs_read_u32_arg(void __user *arg, u32 *value)
+{
+    if (!arg || !value || IS_ERR(arg))
+        return false;
+
+    if ((unsigned long)arg < PAGE_SIZE)
+        return false;
+
+    if (!ksu_access_ok(arg, sizeof(*value)))
+        return false;
+
+    return copy_from_user(value, arg, sizeof(*value)) == 0;
+}

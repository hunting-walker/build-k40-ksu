+
+#define KSU_SUSFS_COMPAT_UMOUNTED BIT(25)
+
+static inline bool ksu_susfs_starts_with(const char *str, const char *prefix)
+{
+    size_t prefix_len;
+
+    if (!str || !prefix)
+        return false;
+
+    prefix_len = strlen(prefix);
+    return strncmp(str, prefix, prefix_len) == 0;
+}
+
+static inline bool ksu_susfs_ends_with(const char *str, const char *suffix)
+{
+    size_t str_len;
+    size_t suffix_len;
+
+    if (!str || !suffix)
+        return false;
+
+    str_len = strlen(str);
+    suffix_len = strlen(suffix);
+    if (str_len < suffix_len)
+        return false;
+
+    return memcmp(str + str_len - suffix_len, suffix, suffix_len) == 0;
+}
+
+static inline bool ksu_susfs_is_current_proc_umounted(void)
+{
+    return !!(READ_ONCE(current->susfs_task_state) & KSU_SUSFS_COMPAT_UMOUNTED);
+}
+
+static inline void ksu_susfs_set_current_proc_umounted(void)
+{
+    task_lock(current);
+    current->susfs_task_state |= KSU_SUSFS_COMPAT_UMOUNTED;
+    task_unlock(current);
+}
+
+#ifdef CONFIG_KSU_SUSFS_TRY_UMOUNT
+extern void susfs_run_try_umount_for_current_mnt_ns(void);
+#endif
+#endif
